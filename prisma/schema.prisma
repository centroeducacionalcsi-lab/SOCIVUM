generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Person {
  id               String   @id @default(cuid())
  type             String
  fullName         String
  socialName       String?
  cpf              String?  @unique
  cnpj             String?
  rg               String?
  birthDate        String?
  gender           String?
  race             String?
  phone            String?
  whatsapp         String?
  email            String?
  zipCode          String?
  address          String?
  number           String?
  complement       String?
  neighborhood     String?
  city             String?
  state            String?
  incomeSource     String?
  individualIncome Float?
  familyIncome     Float?
  vulnerability    String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Family {
  id               String   @id @default(cuid())
  name             String
  responsibleName  String
  responsibleCpf   String?
  address          String?
  neighborhood     String?
  city             String?
  familyIncome     Float?
  housingStatus    String?
  vulnerabilities  String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Beneficiary {
  id          String   @id @default(cuid())
  fullName    String
  cpf         String?
  status      String?
  projectName String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Volunteer {
  id           String   @id @default(cuid())
  fullName     String
  cpf          String?
  skills       String?
  availability String?
  hours        Float?
  notes        String?
  createdAt    DateTime @default(now())
}

model Staff {
  id             String   @id @default(cuid())
  fullName       String
  cpf            String?
  role           String?
  contractType   String?
  projectName    String?
  monthlyValue   Float?
  workload       String?
  notes          String?
  createdAt      DateTime @default(now())
}

model Donor {
  id          String   @id @default(cuid())
  name        String
  document    String?
  contact     String?
  preference  String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Partner {
  id          String   @id @default(cuid())
  name        String
  document    String?
  type        String?
  contact     String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  objectives  String?
  source      String?
  budget      Float?
  received    Float?
  startDate   String?
  endDate     String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Action {
  id             String   @id @default(cuid())
  name           String
  projectName    String?
  description    String?
  date           String?
  time           String?
  location       String?
  responsible    String?
  targetAudience String?
  result         String?
  createdAt      DateTime @default(now())
}

model Workshop {
  id          String   @id @default(cuid())
  name        String
  projectName String?
  instructor  String?
  workload    String?
  period      String?
  vacancies   Int?
  location    String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Attendance {
  id          String   @id @default(cuid())
  personName  String
  cpf         String?
  activity    String?
  date        String
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model SocialAssistance {
  id           String   @id @default(cuid())
  personName   String
  cpf          String?
  date         String?
  professional String?
  demand       String?
  referral     String?
  notes        String?
  createdAt    DateTime @default(now())
}

model PsychologicalAssistance {
  id           String   @id @default(cuid())
  personName   String
  cpf          String?
  date         String?
  professional String?
  status       String?
  notes        String?
  createdAt    DateTime @default(now())
}

model LegalAssistance {
  id           String   @id @default(cuid())
  personName   String
  cpf          String?
  date         String?
  area         String?
  status       String?
  notes        String?
  createdAt    DateTime @default(now())
}

model PedagogicalAssistance {
  id          String   @id @default(cuid())
  personName  String
  cpf         String?
  school      String?
  grade       String?
  difficulty  String?
  evolution   String?
  notes       String?
  createdAt   DateTime @default(now())
}

model FinancialDonation {
  id          String   @id @default(cuid())
  donorName   String
  amount      Float
  date        String?
  method      String?
  destination String?
  projectName String?
  notes       String?
  createdAt   DateTime @default(now())
}

model MaterialDonation {
  id          String   @id @default(cuid())
  donorName   String
  item        String
  quantity    Float?
  unit        String?
  date        String?
  destination String?
  notes       String?
  createdAt   DateTime @default(now())
}

model FinanceEntry {
  id            String   @id @default(cuid())
  type          String
  description   String
  amount        Float
  dueDate       String?
  paidDate      String?
  status        String?
  category      String?
  projectName   String?
  source        String?
  bankAccount   String?
  paymentMethod String?
  reconciled    Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
}

model BankReconciliation {
  id              String   @id @default(cuid())
  description     String
  bankAccount     String?
  transactionDate String?
  amount          Float?
  transactionType String?
  status          String?
  linkedEntry     String?
  notes           String?
  createdAt       DateTime @default(now())
}

model Purchase {
  id          String   @id @default(cuid())
  description String
  requester   String?
  supplier    String?
  projectName String?
  amount      Float?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model StockItem {
  id          String   @id @default(cuid())
  name        String
  category    String?
  unit        String?
  quantity    Float?
  minimum     Float?
  source      String?
  destination String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Asset {
  id          String   @id @default(cuid())
  name        String
  code        String?
  category    String?
  location    String?
  responsible String?
  value       Float?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Contract {
  id          String   @id @default(cuid())
  title       String
  type        String?
  parties     String?
  amount      Float?
  startDate   String?
  endDate     String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Document {
  id          String   @id @default(cuid())
  title       String
  type        String?
  relatedTo   String?
  fileUrl     String?
  expiresAt   String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Accountability {
  id          String   @id @default(cuid())
  projectName String
  period      String?
  status      String?
  pending     String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Opportunity {
  id          String   @id @default(cuid())
  name        String
  organization String?
  deadline    String?
  amount      Float?
  area        String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Communication {
  id          String   @id @default(cuid())
  title       String
  channel     String?
  audience    String?
  message     String?
  status      String?
  createdAt   DateTime @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  date        String?
  time        String?
  responsible String?
  priority    String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  module      String?
  filters     String?
  format      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model Indicator {
  id          String   @id @default(cuid())
  name        String
  area        String?
  target      Float?
  achieved    Float?
  period      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model AiLog {
  id          String   @id @default(cuid())
  question    String
  answer      String?
  module      String?
  userName    String?
  createdAt   DateTime @default(now())
}

model BeneficiaryPortalRequest {
  id          String   @id @default(cuid())
  title       String
  beneficiary String?
  type        String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model DonorPortalRequest {
  id          String   @id @default(cuid())
  title       String
  donorName   String?
  type        String?
  status      String?
  notes       String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  userName    String?
  module      String?
  ip          String?
  notes       String?
  createdAt   DateTime @default(now())
}

model MobileRecord {
  id          String   @id @default(cuid())
  title       String
  type        String?
  personName  String?
  location    String?
  date        String?
  notes       String?
  createdAt   DateTime @default(now())
}
